{
  "expo": {
    "name": "CalorieLog",
    "slug": "calorielog",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "calorielog",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.calorielog.app"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.calorielog.app"
    },
    "platforms": [
      "android",
      "ios"
    ],
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "CalorieLog uses the camera to scan barcodes on food packages."
        }
      ],
      "expo-sqlite",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7dfae828-1db5-4da4-baf7-38f4ff162e53"
      }
    },
    "owner": "jauchen"
  }
}
