# ─── API ──────────────────────────────────────────────────────────────────────
# Base URL of the CalorieLog API (no trailing slash).
# Local development with Android emulator: http://10.0.2.2:3000
# Local development with iOS simulator:    http://localhost:3000
# Production:                              https://your-project.vercel.app
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# ─── Clerk ────────────────────────────────────────────────────────────────────
# Publishable key — safe to expose in the app bundle (EXPO_PUBLIC_ prefix required).
# Source: Clerk dashboard → API Keys → Publishable key
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ─── Error reporting (optional) ───────────────────────────────────────────────
# When set, the error-reporting wrapper (lib/errorReporting.ts) activates.
# Leave blank to keep error reporting disabled (safe default for development).
# To integrate Sentry: set this to your Sentry DSN and wire the SDK in
# lib/errorReporting.ts. Never include food names, calories, or meal content
# in error context.
EXPO_PUBLIC_ERROR_REPORTING_DSN=
