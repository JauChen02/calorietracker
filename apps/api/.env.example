# ─── Neon Postgres ────────────────────────────────────────────────────────────
# Pooled connection string — used by the API at runtime.
# Source: Neon console → Project → Connection Details → Connection string
# Select "Pooled connection" and copy the postgres:// URL.
DATABASE_URL=

# Direct (unpooled) connection string — used by Drizzle migrations only.
# Source: Neon console → Project → Connection Details
# Uncheck "Connection pooling" and copy the postgres:// URL.
DATABASE_URL_UNPOOLED=

# ─── Runtime environment ──────────────────────────────────────────────────────
# One of: development | staging | production
# Defaults to "development" when absent.
API_ENV=development

# ─── Clerk ────────────────────────────────────────────────────────────────────
# Server-side secret — NEVER expose this to the client or mobile app.
# Source: Clerk dashboard → API Keys → Secret keys
CLERK_SECRET_KEY=

# Publishable key — safe to expose in the browser bundle.
# Source: Clerk dashboard → API Keys → Publishable key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ─── Food data provider ───────────────────────────────────────────────────────
# Controls which external food database is used for food search and barcode lookup.
# Valid values:
#   disabled         — food search endpoints return 503; manual entry still works (default)
#   open_food_facts  — use Open Food Facts (free, no API key required)
#
# Open Food Facts data is community-contributed under the Open Database Licence (ODbL).
# It is NOT clinically verified. Results carry verificationStatus: "community".
# See: https://world.openfoodfacts.org/terms-of-use
FOOD_DATA_PROVIDER=disabled
