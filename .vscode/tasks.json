{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev:api",
      "type": "shell",
      "command": "pnpm dev:api",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "dev"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "starting",
          "endsPattern": "ready"
        }
      }
    },
    {
      "label": "dev:mobile",
      "type": "shell",
      "command": "pnpm dev:mobile",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "dev"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "test",
      "type": "shell",
      "command": "pnpm test",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "pnpm lint",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "typecheck",
      "type": "shell",
      "command": "pnpm typecheck",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "db:generate",
      "type": "shell",
      "command": "pnpm db:generate",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "db:migrate",
      "type": "shell",
      "command": "pnpm db:migrate",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "android:emulator",
      "type": "shell",
      "command": "emulator -avd $(emulator -list-avds | head -1)",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "dev"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
